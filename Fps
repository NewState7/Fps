-------------------------------------------------
-- DELETE 80% MAP FUNCTION
-------------------------------------------------
local function delete80Map()
    local objects={}
    for _,obj in pairs(workspace:GetDescendants()) do
        if (obj:IsA("BasePart") or obj:IsA("Model"))
        and not obj:IsDescendantOf(game.Players)
        and obj.Name~="Terrain"
        and obj.Name~="Camera" then
            table.insert(objects,obj)
        end
    end

    local total=#objects
    local deleteCount=math.floor(total*0.8)

    for i=total,2,-1 do
        local j=math.random(i)
        objects[i],objects[j]=objects[j],objects[i]
    end

    for i=1,deleteCount do
        if objects[i] and objects[i].Parent then
            objects[i]:Destroy()
        end
    end

    btn.Text="DONE ✔"
end

